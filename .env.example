DEPLOYER_PRIVATE_KEY=78260da03d026d819f667cdddd632e6448f25bd58b86e5963e58e11a1a4f3e5d
# ─── SAYMAN RPC endpoints ─────────────────────────────────────────────────────
SAYMAN_RPC=https://sayman.onrender.com
# SAYMAN_MAINNET_RPC=https://mainnet.sayman.io

# ─── Deployer wallet ─────────────────────────────────────────────────────────
# Private key of the wallet that pays gas for contract deployment.
# Leave blank on local dev (an ephemeral key will be generated).
# DEPLOYER_PRIVATE_KEY=your_64_char_hex_private_key_here

# ─── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Gemini Vision AI ────────────────────────────────────────────────────────
# Required for POST /api/ai/analyze (image classification via Gemini 2.5 Flash)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Pinata IPFS Storage ──────────────────────────────────────────────────────
# Required for POST /api/ipfs/upload (evidence storage)
# Get JWT: https://app.pinata.cloud  →  API Keys  →  New Key  →  Admin  →  Copy JWT
PINATA_JWT=your_pinata_jwt_here

# ─── Vite (frontend) ─────────────────────────────────────────────────────────
# Only needed if backend runs on a non-default URL in production
# VITE_API_URL=https://your-backend.onrender.com